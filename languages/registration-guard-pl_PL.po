#: views/emails/verification-email.php:39
#, php-format
msgid "This link will expire in %d hours. If you did not register, you can safely ignore this email."
msgstr "Ten link wygaśnie za %d godzin. Jeśli nie zarejestrowałeś się, możesz bezpiecznie zignorować tę wiadomość e-mail."

#. translators: %s: site name
#: views/emails/verification-email.php:47
#, php-format
msgid "This email was sent by %s."
msgstr "Ta wiadomość e-mail została wysłana przez %s."